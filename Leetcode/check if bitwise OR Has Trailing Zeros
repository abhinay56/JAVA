class Solution {
    public boolean hasTrailingZeros(int[] nums) {
        int c = 0;
        boolean ans = false;
        for(int  i = 0; i < nums.length; i++){
            if(nums[i] % 2 == 0){
                c++;
            }
            if(c == 2){
                ans = true;
                break;
            }
        }
        return ans;
    }
}
