class Solution {
    public int lastStoneWeight(int[] stones) {
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        for(int s : stones) pq.add(s);
        while(pq.size() > 1){
            int m1 = pq.remove();
            int m2 = pq.remove();
            if(m1 != m2){
                pq.add(m1 - m2);
            }
        }
        if(pq.isEmpty()) return 0;
        return pq.peek();
    }
}
